{
  "private": true,
  "license": "MIT",
  "scripts": {
    "format": "sort-package-json && prettier . --write && eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint": "sort-package-json --check && prettier . --check && eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "prepare": "husky install",
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test": "vitest run --coverage --environment jsdom --root ui/",
    "test:fast": "vitest run --environment jsdom --root ui/",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false"
  },
  "dependencies": {
    "pinia": "2.0.28",
    "vue": "3.2.45",
    "vue-router": "4.1.6"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.2.0",
    "@types/jsdom": "20.0.1",
    "@types/node": "18.11.13",
    "@vitejs/plugin-vue": "4.0.0",
    "@vitest/coverage-c8": "0.25.7",
    "@vue/eslint-config-prettier": "7.0.0",
    "@vue/eslint-config-typescript": "11.0.2",
    "@vue/test-utils": "2.2.6",
    "@vue/tsconfig": "0.1.3",
    "eslint": "8.29.0",
    "eslint-plugin-vue": "9.8.0",
    "happy-dom": "8.1.0",
    "husky": "8.0.2",
    "jsdom": "20.0.3",
    "npm-run-all": "4.1.5",
    "prettier": "2.8.1",
    "sass": "1.56.2",
    "sort-package-json": "2.1.0",
    "typescript": "4.9.4",
    "vite": "4.0.0",
    "vitest": "0.25.7",
    "vue-tsc": "1.0.12"
  }
}
